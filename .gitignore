# -------------------------
# IGNORE LARGE DATA FILES
# -------------------------
data/raw/*.csv
data/processed/*.parquet

# Ignore ALL features first
data/features/*

# Then allow ONLY required ones
!data/features/
!data/features/feature_matrix_ensemble_scored.parquet

# -------------------------
# MODELS
# -------------------------
models/autoencoder/*
!models/autoencoder/
# (Do NOT upload .pt if large)

models/isolation_forest/*
!models/isolation_forest/
!models/isolation_forest/shap_importance.json

# -------------------------
# REPORTS
# -------------------------
reports/*
!reports/alerts/
!reports/alerts/alert_table.csv
